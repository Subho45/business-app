# Server Configuration
PORT=5000

# JWT Secret (Generate a new one for production!)
JWT_SECRET=your_jwt_secret_key_here

# Frontend URL (Set this to your Vercel frontend URL)
FRONTEND_URL=https://business-app-3r2g.vercel.app
# PostgreSQL Database URL
# For local development: postgres://user:password@localhost:5432/businessapp
# For Neon: Copy from neon.tech project settings
# For Vercel Postgres: Copy from Vercel dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/businessapp

# Environment
NODE_ENV=development
